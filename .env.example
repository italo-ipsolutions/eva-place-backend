# === SERVIDOR ===
# Porta do servidor (Hostinger pode atribuir automaticamente)
PORT=3100
# Host de bind (0.0.0.0 para aceitar conexoes externas)
HOST=0.0.0.0

# === BASE DE CONTEXTO ===
# Caminho para a pasta BACKEND_BASE com os JSONs
# Ja inclusa no repositorio — default: ./BACKEND_BASE
# Sobrescreva apenas se mover a pasta para outro local no servidor
CONTEXT_BASE_PATH=./BACKEND_BASE

# === OPENAI ===
OPENAI_API_KEY=sk-proj-...
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# === SEGURANCA ===
# Webhook Secret — OBRIGATORIO em producao
# Mesmo valor configurado no ManyChat External Request header X-Webhook-Secret
WEBHOOK_SECRET=

# === NODE ENV ===
# development | production
NODE_ENV=production
